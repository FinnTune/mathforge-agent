# Copy to ".env" and fill in secrets. Never commit ".env".
# python-dotenv loads this file when you run `python main.py` (see main.async_main).

# --- Required ---
# Anthropic console: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Optional: LLM behavior (agent / Claude) ---
# Model id passed to ChatAnthropic (override default in config.load_settings).
# MATHFORGE_MODEL=claude-sonnet-4-6
# Sampling temperature (0 = deterministic-ish; higher = more random).
# MATHFORGE_TEMPERATURE=0
# Hard cap on completion tokens (leave unset for provider default).
# MATHFORGE_MAX_TOKENS=
# LangGraph recursion_limit: max steps in the ReAct loop (model + tool calls).
# MATHFORGE_RECURSION_LIMIT=40

# --- Optional: code sandbox (subprocess in sandbox.py) ---
# Working directory for executed code; relative paths like ./plots/ resolve here.
# main.py copies this into os.environ for tools.execute_python_code.
# MATHFORGE_WORKSPACE_ROOT=.
# Seconds before subprocess.run kills the child (infinite loops, hung code).
# MATHFORGE_CODE_TIMEOUT_SEC=30

# --- Optional: logging ---
# Python logging level name: DEBUG, INFO, WARNING, ERROR.
# MATHFORGE_LOG_LEVEL=INFO

# --- Optional: LangSmith (LangChain observability) ---
# Docs: https://docs.smith.langchain.com/
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=mathforge
