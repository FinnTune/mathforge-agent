# Required: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — agent
# MATHFORGE_MODEL=claude-sonnet-4-6
# MATHFORGE_TEMPERATURE=0
# MATHFORGE_MAX_TOKENS=
# MATHFORGE_RECURSION_LIMIT=40

# Optional — subprocess sandbox (code execution)
# MATHFORGE_WORKSPACE_ROOT=.
# MATHFORGE_CODE_TIMEOUT_SEC=30

# Optional — logging (DEBUG, INFO, WARNING, ERROR)
# MATHFORGE_LOG_LEVEL=INFO

# Optional — LangSmith tracing (https://docs.smith.langchain.com/)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=mathforge
